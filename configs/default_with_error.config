server {
    listen 8080;
    root ./www;
    index index.html;

    error_page 404 ./www/errors/404.html;
    error_page 405 ./www/errors/405.html;
    error_page 403 ./www/errors/403.html;

    location / {
        methods GET POST DELETE;
    }

    location /images {
        root ./www/images;
        methods GET;
    }

    location /old {
        return 301 /new;
    }

    location /upload {
    root ./www;
    methods POST;
    upload_dir ./www/uploads;
    client_max_body_size 10M;
    }

    location /uploads {
    root ./www/uploads;
    methods GET DELETE;
    autoindex on;
}

    location /cgi {
    root ./www/cgi;
    methods GET POST;
    cgi_ext .py;
    cgi /usr/bin/python3;
}

}
